<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>VELOR AGENCY™ — Construímos Poder Digital</title>
<meta name="description" content="Agência criativa premium para servidores FiveM, branding, motion design, redes sociais e soluções criativas completas no mundo todo."/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
--c1:#0a0a0b;
--c2:#111114;
--c3:#1a1a20;
--neon:#00f5c8;
--neon2:#7b5cfa;
--neon3:#ff3d6e;
--gold:#c9a84c;
--text:#e8e8f0;
--muted:#6b6b80;
--border:rgba(255,255,255,0.06);
--ff-head:'Bebas Neue',sans-serif;
--ff-body:'DM Sans',sans-serif;
--ff-mono:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth}
body{
background:var(--c1);
color:var(--text);
font-family:var(--ff-body);
font-size:16px;
line-height:1.6;
overflow-x:hidden;
cursor:none;
}

/* ── CURSOR ── */
#cursor{
position:fixed;
width:12px;height:12px;
background:var(--neon);
border-radius:50%;
pointer-events:none;
z-index:9999;
mix-blend-mode:difference;
transition:transform 0.15s ease;
}
#cursor-ring{
position:fixed;
width:40px;height:40px;
border:1px solid rgba(0,245,200,0.4);
border-radius:50%;
pointer-events:none;
z-index:9998;
transition:all 0.12s ease;
}

/* ── LOADER ── */
#loader{
position:fixed;inset:0;
background:var(--c1);
z-index:10000;
display:flex;flex-direction:column;
align-items:center;justify-content:center;
transition:opacity 0.8s ease, visibility 0.8s ease;
}
#loader.hidden{opacity:0;visibility:hidden;pointer-events:none}
.loader-logo{
font-family:var(--ff-head);
font-size:clamp(2rem,6vw,4rem);
letter-spacing:0.2em;
background:linear-gradient(135deg,#fff 0%,var(--neon) 50%,var(--neon2) 100%);
-webkit-background-clip:text;-webkit-text-fill-color:transparent;
animation:pulseText 1.5s ease-in-out infinite;
}
.loader-bar-wrap{
width:200px;height:1px;
background:rgba(255,255,255,0.08);
margin-top:2rem;
overflow:hidden;
}
.loader-bar{
height:100%;
background:linear-gradient(90deg,var(--neon),var(--neon2));
width:0%;
animation:loadBar 2.2s ease-in-out forwards;
}
.loader-text{
font-family:var(--ff-mono);
font-size:0.65rem;
color:var(--muted);
letter-spacing:0.3em;
margin-top:1rem;
animation:fadeIn 0.5s ease 0.3s both;
}
@keyframes loadBar{to{width:100%}}
@keyframes pulseText{0%,100%{opacity:1}50%{opacity:0.6}}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ── NOISE ── */
#noise{
position:fixed;inset:0;
pointer-events:none;
z-index:1;
opacity:0.025;
background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
background-size:128px 128px;
}

/* ── NAV ── */
nav{
position:fixed;top:0;left:0;right:0;
z-index:1000;
padding:1.2rem 3rem;
display:flex;align-items:center;justify-content:space-between;
border-bottom:1px solid transparent;
transition:all 0.4s ease;
}
nav.scrolled{
background:rgba(10,10,11,0.85);
backdrop-filter:blur(20px);
border-bottom-color:var(--border);
}
.nav-logo{
font-family:var(--ff-head);
font-size:1.4rem;
letter-spacing:0.15em;
color:#fff;
text-decoration:none;
background:none;border:none;cursor:none;
}
.nav-logo span{color:var(--neon)}
.nav-links{
display:flex;gap:2.5rem;align-items:center;
}
.nav-links a{
font-family:var(--ff-mono);
font-size:0.72rem;
letter-spacing:0.2em;
text-transform:uppercase;
color:var(--muted);
text-decoration:none;
transition:color 0.3s ease;
position:relative;
}
.nav-links a::after{
content:'';
position:absolute;
bottom:-2px;left:0;right:100%;height:1px;
background:var(--neon);
transition:right 0.3s ease;
}
.nav-links a:hover{color:var(--neon)}
.nav-links a:hover::after{right:0}
.nav-cta{
background:transparent !important;
border:1px solid var(--neon) !important;
color:var(--neon) !important;
padding:0.5rem 1.2rem !important;
border-radius:2px !important;
letter-spacing:0.15em !important;
transition:all 0.3s ease !important;
}
.nav-cta:hover{
background:var(--neon) !important;
color:var(--c1) !important;
}
.nav-cta::after{display:none !important}
.nav-btn-internal{
font-family:var(--ff-mono);
font-size:0.72rem;
letter-spacing:0.2em;
text-transform:uppercase;
color:var(--muted);
background:none;border:none;
cursor:none;
transition:color 0.3s ease;
position:relative;
padding:0;
}
.nav-btn-internal::after{
content:'';
position:absolute;
bottom:-2px;left:0;right:100%;height:1px;
background:var(--neon);
transition:right 0.3s ease;
}
.nav-btn-internal:hover{color:var(--neon)}
.nav-btn-internal:hover::after{right:0}

/* ── HERO ── */
#hero{
position:relative;
min-height:100vh;
display:flex;flex-direction:column;
align-items:center;justify-content:center;
overflow:hidden;
padding:8rem 2rem 4rem;
}
.hero-grid{
position:absolute;inset:0;
background-image:
linear-gradient(rgba(0,245,200,0.03) 1px, transparent 1px),
linear-gradient(90deg, rgba(0,245,200,0.03) 1px, transparent 1px);
background-size:60px 60px;
animation:gridPan 20s linear infinite;
z-index:0;
}
@keyframes gridPan{from{background-position:0 0}to{background-position:60px 60px}}
.hero-glow{
position:absolute;
border-radius:50%;
filter:blur(80px);
pointer-events:none;
}
.hero-glow-1{
width:600px;height:600px;
background:radial-gradient(circle,rgba(0,245,200,0.12) 0%,transparent 70%);
top:-100px;left:-100px;
animation:float1 8s ease-in-out infinite;
}
.hero-glow-2{
width:500px;height:500px;
background:radial-gradient(circle,rgba(123,92,250,0.12) 0%,transparent 70%);
bottom:-100px;right:-100px;
animation:float2 10s ease-in-out infinite;
}
.hero-glow-3{
width:300px;height:300px;
background:radial-gradient(circle,rgba(255,61,110,0.08) 0%,transparent 70%);
top:50%;left:50%;transform:translate(-50%,-50%);
animation:float1 6s ease-in-out infinite 2s;
}
@keyframes float1{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-30px) scale(1.05)}}
@keyframes float2{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(20px) scale(0.95)}}
.hero-content{
position:relative;z-index:2;
text-align:center;
max-width:1100px;
}
.hero-tag{
display:inline-flex;align-items:center;gap:0.5rem;
font-family:var(--ff-mono);
font-size:0.65rem;
letter-spacing:0.4em;
color:var(--neon);
border:1px solid rgba(0,245,200,0.2);
padding:0.4rem 1rem;
border-radius:2px;
margin-bottom:2rem;
animation:fadeIn 0.8s ease both;
}
.hero-tag::before{
content:'';
width:6px;height:6px;
background:var(--neon);
border-radius:50%;
animation:blink 1.5s ease-in-out infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}
.hero-title{
font-family:var(--ff-head);
font-size:clamp(4rem,12vw,10rem);
line-height:0.9;
letter-spacing:-0.02em;
color:#fff;
margin-bottom:0.3em;
animation:fadeIn 0.8s ease 0.2s both;
}
.hero-title .neon-word{
background:linear-gradient(135deg,var(--neon) 0%,#00c4a0 100%);
-webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.hero-sub{
font-size:clamp(0.9rem,2vw,1.1rem);
color:var(--muted);
max-width:550px;
margin:0 auto 3rem;
animation:fadeIn 0.8s ease 0.4s both;
}
.hero-ctas{
display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;
animation:fadeIn 0.8s ease 0.6s both;
}
.btn-primary{
display:inline-flex;align-items:center;gap:0.5rem;
background:var(--neon);
color:var(--c1);
font-family:var(--ff-mono);
font-size:0.72rem;
letter-spacing:0.2em;
text-transform:uppercase;
padding:0.9rem 2rem;
text-decoration:none;
border:none;
font-weight:700;
transition:all 0.3s ease;
clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));
cursor:none;
}
.btn-primary:hover{
background:#fff;
transform:translateY(-2px);
box-shadow:0 0 30px rgba(0,245,200,0.4);
}
.btn-ghost{
display:inline-flex;align-items:center;gap:0.5rem;
background:transparent;
color:var(--text);
font-family:var(--ff-mono);
font-size:0.72rem;
letter-spacing:0.2em;
text-transform:uppercase;
padding:0.9rem 2rem;
text-decoration:none;
border:1px solid var(--border);
transition:all 0.3s ease;
clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));
cursor:none;
}
.btn-ghost:hover{
border-color:var(--neon2);
color:var(--neon2);
transform:translateY(-2px);
box-shadow:0 0 30px rgba(123,92,250,0.2);
}

/* Floating cards */
.hero-cards{position:absolute;z-index:1;pointer-events:none;}
.hero-card{
background:rgba(255,255,255,0.03);
border:1px solid rgba(255,255,255,0.08);
backdrop-filter:blur(12px);
border-radius:8px;
padding:1rem 1.2rem;
font-family:var(--ff-mono);
}
.hero-card-left{left:2%;top:30%;animation:floatCard1 7s ease-in-out infinite;}
.hero-card-right{right:2%;top:35%;animation:floatCard2 8s ease-in-out infinite 1s;}
.hero-card-bottom{bottom:15%;left:8%;animation:floatCard1 9s ease-in-out infinite 2s;}
@keyframes floatCard1{0%,100%{transform:translateY(0) rotate(-1deg)}50%{transform:translateY(-15px) rotate(1deg)}}
@keyframes floatCard2{0%,100%{transform:translateY(0) rotate(1deg)}50%{transform:translateY(-20px) rotate(-1deg)}}
.hcard-label{font-size:0.55rem;color:var(--muted);letter-spacing:0.3em;margin-bottom:0.3rem}
.hcard-val{font-size:1.2rem;color:var(--neon);font-weight:700}
.hcard-sub{font-size:0.6rem;color:var(--muted)}
.hcard-dot{display:inline-block;width:6px;height:6px;background:var(--neon);border-radius:50%;margin-right:4px;animation:blink 1s ease-in-out infinite;}

.scroll-ind{
position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);
display:flex;flex-direction:column;align-items:center;gap:0.5rem;z-index:2;
animation:fadeIn 1s ease 1.5s both;
}
.scroll-ind span{font-family:var(--ff-mono);font-size:0.6rem;letter-spacing:0.3em;color:var(--muted);}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--neon),transparent);animation:scrollLine 2s ease-in-out infinite;}
@keyframes scrollLine{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

/* ── SECTIONS ── */
section{position:relative;padding:6rem 2rem;}
.section-inner{max-width:1200px;margin:0 auto}
.section-label{
font-family:var(--ff-mono);font-size:0.62rem;letter-spacing:0.4em;color:var(--neon);
text-transform:uppercase;margin-bottom:1rem;display:flex;align-items:center;gap:0.8rem;
}
.section-label::before{content:'';width:24px;height:1px;background:var(--neon);}
.section-title{
font-family:var(--ff-head);font-size:clamp(2.5rem,6vw,5rem);line-height:1;
color:#fff;letter-spacing:-0.01em;margin-bottom:1.5rem;
}

/* ── MARQUEE ── */
.marquee-wrap{
overflow:hidden;border-top:1px solid var(--border);border-bottom:1px solid var(--border);
padding:1rem 0;background:rgba(0,0,0,0.2);
}
.marquee-track{display:flex;gap:3rem;animation:marquee 20s linear infinite;white-space:nowrap;}
.marquee-item{font-family:var(--ff-head);font-size:1.1rem;letter-spacing:0.15em;color:var(--muted);display:flex;align-items:center;gap:1rem;}
.marquee-item .dot{width:4px;height:4px;background:var(--neon);border-radius:50%;}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── ABOUT ── */
#about{background:var(--c2)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;}
.about-text p{color:var(--muted);margin-bottom:1.2rem;font-size:1.05rem;line-height:1.8;}
.about-text strong{color:var(--text)}
.about-accent{font-family:var(--ff-head);font-size:clamp(1.5rem,3vw,2.5rem);color:var(--neon);display:block;margin-bottom:1.5rem;}
.about-visual{position:relative;height:400px;}
.about-box{position:absolute;background:var(--c3);border:1px solid var(--border);border-radius:4px;padding:1.5rem;}
.about-box-main{
inset:0;display:flex;flex-direction:column;justify-content:flex-end;
background:linear-gradient(135deg,rgba(0,245,200,0.05) 0%,rgba(123,92,250,0.05) 100%);
border-color:rgba(0,245,200,0.15);
}
.about-badge{
position:absolute;top:-1px;left:-1px;
background:var(--neon);color:var(--c1);font-family:var(--ff-mono);font-size:0.6rem;
letter-spacing:0.2em;padding:0.3rem 0.8rem;font-weight:700;
}
.about-number{font-family:var(--ff-head);font-size:4rem;color:#fff;line-height:1;}
.about-num-label{font-family:var(--ff-mono);font-size:0.65rem;color:var(--muted);letter-spacing:0.2em;}

/* ── STATS ── */
#stats{background:var(--c1);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:4rem 2rem;}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;}
.stat-item{text-align:center;padding:2rem;border-right:1px solid var(--border);}
.stat-item:last-child{border-right:none}
.stat-num{
font-family:var(--ff-head);font-size:clamp(2.5rem,5vw,4rem);line-height:1;
background:linear-gradient(135deg,#fff 0%,var(--neon) 100%);
-webkit-background-clip:text;-webkit-text-fill-color:transparent;display:block;
}
.stat-label{font-family:var(--ff-mono);font-size:0.65rem;letter-spacing:0.25em;color:var(--muted);text-transform:uppercase;margin-top:0.5rem;display:block;}

/* ── SERVICES ── */
#services{background:var(--c2)}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:3rem;}
.service-card{
background:var(--c2);padding:2.5rem 2rem;position:relative;overflow:hidden;
transition:background 0.4s ease;cursor:none;
}
.service-card::before{
content:'';position:absolute;inset:0;
background:linear-gradient(135deg,rgba(0,245,200,0.04) 0%,rgba(123,92,250,0.04) 100%);
opacity:0;transition:opacity 0.4s ease;
}
.service-card:hover{background:var(--c3)}
.service-card:hover::before{opacity:1}
.service-num{font-family:var(--ff-mono);font-size:0.6rem;color:var(--neon);letter-spacing:0.3em;margin-bottom:1.5rem;display:block;}
.service-icon{font-size:1.8rem;margin-bottom:1rem;display:block;}
.service-name{font-family:var(--ff-head);font-size:1.6rem;letter-spacing:0.05em;color:#fff;margin-bottom:0.8rem;}
.service-desc{font-size:0.875rem;color:var(--muted);line-height:1.7;}
.service-arrow{
position:absolute;bottom:1.5rem;right:1.5rem;width:32px;height:32px;
border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;
color:var(--muted);font-size:0.9rem;transition:all 0.3s ease;
}
.service-card:hover .service-arrow{border-color:var(--neon);color:var(--neon);transform:rotate(45deg);}

/* ── WHY ── */
#why{background:var(--c1)}
.why-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;margin-top:4rem;}
.why-item{padding:2rem 0;border-top:1px solid var(--border);display:flex;gap:1.5rem;}
.why-num{font-family:var(--ff-head);font-size:2.5rem;color:rgba(0,245,200,0.15);line-height:1;min-width:3rem;}
.why-content h3{font-family:var(--ff-head);font-size:1.4rem;letter-spacing:0.05em;color:#fff;margin-bottom:0.5rem;}
.why-content p{font-size:0.875rem;color:var(--muted);line-height:1.7;}

/* ── CTA ── */
#cta-banner{background:var(--c3);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:5rem 2rem;text-align:center;position:relative;overflow:hidden;}
#cta-banner::before{
content:'';position:absolute;width:500px;height:500px;
background:radial-gradient(circle,rgba(0,245,200,0.08) 0%,transparent 70%);
top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;
}
.cta-banner-title{font-family:var(--ff-head);font-size:clamp(2.5rem,7vw,6rem);line-height:0.95;color:#fff;letter-spacing:-0.01em;margin-bottom:1.5rem;}
.cta-banner-title span{background:linear-gradient(135deg,var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.cta-banner-sub{font-size:1rem;color:var(--muted);margin-bottom:2.5rem;}
.cta-row{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;}

/* ── TERMS ── */
#terms{display:none}
#terms.active{display:block}
.terms-hero{padding:8rem 2rem 4rem;text-align:center;border-bottom:1px solid var(--border);}
.terms-title{font-family:var(--ff-head);font-size:clamp(3rem,8vw,6rem);color:#fff;letter-spacing:-0.01em;}
.terms-sub{font-family:var(--ff-mono);font-size:0.7rem;color:var(--muted);letter-spacing:0.3em;margin-top:1rem;}
.terms-body{max-width:800px;margin:4rem auto;padding:0 2rem;}
.terms-section{
background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:8px;
padding:2rem;margin-bottom:1.5rem;transition:border-color 0.3s ease;
}
.terms-section:hover{border-color:rgba(0,245,200,0.2)}
.terms-section-num{font-family:var(--ff-mono);font-size:0.6rem;color:var(--neon);letter-spacing:0.3em;margin-bottom:0.5rem;}
.terms-section-title{font-family:var(--ff-head);font-size:1.4rem;letter-spacing:0.05em;color:#fff;margin-bottom:1.2rem;}
.terms-section ul{list-style:none;}
.terms-section ul li{font-size:0.9rem;color:var(--muted);line-height:1.8;padding:0.3rem 0;padding-left:1.2rem;position:relative;}
.terms-section ul li::before{content:'—';position:absolute;left:0;color:var(--neon);font-size:0.7rem;}
.terms-footer-note{
background:rgba(0,245,200,0.04);border:1px solid rgba(0,245,200,0.15);border-radius:4px;
padding:1.5rem;margin-top:2rem;font-family:var(--ff-mono);font-size:0.8rem;color:var(--neon);
text-align:center;line-height:1.6;
}

/* ── FOOTER ── */
footer{background:var(--c1);border-top:1px solid var(--border);padding:3rem 2rem;}
.footer-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:2rem;}
.footer-logo{font-family:var(--ff-head);font-size:1.2rem;letter-spacing:0.15em;color:#fff;}
.footer-logo span{color:var(--neon)}
.footer-copy{font-family:var(--ff-mono);font-size:0.62rem;color:var(--muted);letter-spacing:0.2em;}
.footer-links{display:flex;gap:2rem;}
.footer-links a{font-family:var(--ff-mono);font-size:0.62rem;letter-spacing:0.2em;color:var(--muted);text-decoration:none;text-transform:uppercase;transition:color 0.3s ease;}
.footer-links a:hover{color:var(--neon)}
.footer-btn{font-family:var(--ff-mono);font-size:0.62rem;letter-spacing:0.2em;color:var(--muted);background:none;border:none;cursor:none;text-transform:uppercase;transition:color 0.3s ease;padding:0;}
.footer-btn:hover{color:var(--neon)}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(40px);transition:all 0.8s cubic-bezier(0.16,1,0.3,1);}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-delay-1{transition-delay:0.1s}.reveal-delay-2{transition-delay:0.2s}
.reveal-delay-3{transition-delay:0.3s}.reveal-delay-4{transition-delay:0.4s}
